{
  "name": "affiliate-ad-spy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx src/scrape-ads.ts",
    "reprocess": "tsx src/reprocess-output.ts",
    "deep-analyze": "tsx src/deep-analyze.ts",
    "pipeline": "npm run scrape && npm run deep-analyze",
    "scrape:ac": "VERTICAL=ac tsx src/scrape-ads.ts",
    "deep-analyze:ac": "VERTICAL=ac tsx src/deep-analyze.ts",
    "pipeline:ac": "npm run scrape:ac && npm run deep-analyze:ac",
    "refresh-previews:ac": "VERTICAL=ac tsx src/refresh-previews.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "apify-client": "^2.12.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
